msgstr "Return (callback) URL"

msgid "plugins.paymethod.multipay.paymentSelection"
msgstr "Select Payment Method"

msgid "plugins.paymethod.multipay.paymentDescription"
msgstr "You are about to pay %s %s. Please select a payment gateway below."

