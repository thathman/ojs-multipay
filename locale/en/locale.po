msgid "plugins.paymethod.multipay.displayName"
msgstr "Multi-Gateway Payment"

msgid "plugins.paymethod.multipay.description"
msgstr "Routes payments across multiple installed OJS gateways with currency-aware checkout."

msgid "plugins.paymethod.multipay.settings.testMode"
msgstr "Test Mode"

msgid "plugins.paymethod.multipay.settings.allowedCurrencies"
msgstr "Allowed Currencies"

msgid "plugins.paymethod.multipay.settings.allowedCurrencies.description"
msgstr "Enter comma-separated currency codes (e.g., USD, NGN, GBP)."

msgid "plugins.paymethod.multipay.settings.enabledGateways"
msgstr "Enabled Gateways"

msgid "plugins.paymethod.multipay.settings.pluginMode"
msgstr "Payment Plugin Mode"

msgid "plugins.paymethod.multipay.settings.pluginMode.value"
msgstr "MultiPay is active as the journal payment orchestrator."

msgid "plugins.paymethod.multipay.settings.gatewayCurrencies"
msgstr "Supported Currencies per Gateway"

msgid "plugins.paymethod.multipay.settings.gatewayCurrencies.description"
msgstr "For each gateway, tick the currencies it should accept. Only currencies the gateway can actually settle are listed. The journal currency must be ticked for a gateway to appear at checkout."

msgid "plugins.paymethod.multipay.settings.paystackPublicKey"
msgstr "Paystack Public Key"

msgid "plugins.paymethod.multipay.settings.paystackSecretKey"
msgstr "Paystack Secret Key"

