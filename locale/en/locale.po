msgstr "Paystack"

msgid "plugins.paymethod.multipay.gateway.flutterwave"
msgstr "Flutterwave"

msgid "plugins.paymethod.multipay.error.noGateways"
msgstr "No payment gateways are currently available for this currency."

msgid "plugins.paymethod.multipay.error.initiationFailed"
msgstr "Payment initiation failed."

msgid "plugins.paymethod.multipay.error.generic"
msgstr "We could not process your payment request. Please return to the payment page and try again, or contact the journal if the problem persists."

msgid "plugins.paymethod.multipay.error.verificationFailed"
msgstr "Payment verification failed."

