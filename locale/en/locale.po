msgstr "Flutterwave Webhook Secret"

msgid "plugins.paymethod.multipay.settings.gatewayRoutingJson"
msgstr "Currency Routing Map (JSON)"

msgid "plugins.paymethod.multipay.settings.gatewayRoutingJson.description"
msgstr "Map currency code to default gateway, e.g. {\"NGN\":\"paystack\",\"USD\":\"flutterwave\"}."

msgid "plugins.paymethod.multipay.settings.fallbackGateway"
msgstr "Fallback Gateway"

msgid "plugins.paymethod.multipay.settings.fallbackGateway.description"
msgstr "Gateway used when no other rule selects one for the journal currency."

msgid "plugins.paymethod.multipay.settings.fallbackGateway.none"
msgstr "— None —"

